# ============================================================
# Public (exposed to browser via NEXT_PUBLIC_*)
# ============================================================

NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# USDC on Stellar testnet (SAC contract address)
# Source: @x402/stellar package
NEXT_PUBLIC_USDC_CONTRACT=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# ============================================================
# Server-side (x402 payment flow)
# ============================================================

# x402 facilitator URL
# Coinbase-hosted, supports stellar:testnet with sponsored fees
# Check supported networks: curl https://x402.org/facilitator/supported
X402_FACILITATOR_URL=https://x402.org/facilitator

# Stellar network for x402 (CAIP-2 format)
X402_STELLAR_NETWORK=stellar:testnet

# ============================================================
# TipJar Soroban contract (Phase 6)
# ============================================================

# Contract ID (printed by `pnpm deploy:tipjar`)
TIPJAR_CONTRACT_ID=

# Account index used for the server wallet (derived from TEST_MNEMONIC)
# This wallet signs record_tip calls and pays TTL rent on testnet.
SERVER_ACCOUNT_INDEX=2

# ============================================================
# Test script only (scripts/test-x402.ts) — DO NOT COMMIT
# ============================================================

# Freighter recovery phrase (12 or 24 words)
# Used ONLY by the test script to derive a signing key locally.
# Put the real mnemonic in .env.local (gitignored), NOT here.
TEST_MNEMONIC="word1 word2 word3 ..."

# Account index in the HD derivation path (SEP-0005: m/44'/148'/{index}')
# 0 = first account in Freighter, 1 = second, etc.
TEST_ACCOUNT_INDEX=1

# Target URL for the test script (change to a real creator slug once deployed)
TEST_URL=http://localhost:3000/api/tip/alice
